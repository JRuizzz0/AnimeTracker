<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.animetracker.controller.AnimeController"
      spacing="10"
      alignment="CENTER">

    <Label text="Mi Lista de Anime" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <TableView fx:id="tablaAnimes" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colTitulo" text="Título" prefWidth="200"/>
            <TableColumn fx:id="colEstado" text="Estado" prefWidth="100"/>
            <TableColumn fx:id="colPuntuacion" text="Nota" prefWidth="50"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER" >
        <TextField fx:id="txtTitulo" promptText="Título"/>
        <TextField fx:id="txtGenero" promptText="Género"/>
        <Button text="Añadir" onAction="#Guardar"/>
        <Button text="Actualizar" onAction="#Actualizar" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
        <Button text="Eliminar" onAction="#Eliminar" style="-fx-background-color: red; -fx-text-fill: white;"/>
    </HBox>
</VBox>